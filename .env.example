# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Embeddings (Phase 2) ─────────────────────────────────────────────────────
# Voyage AI is the recommended embedding provider when using Claude.
# voyage-3 outputs 1024-dim vectors; matches schema_embeddings table definition.
# Get a key at https://www.voyageai.com/
VOYAGE_API_KEY=your_voyage_api_key_here
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIM=1024

# ── Database (admin — used by backend and seed script) ────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=querymind
DB_USER=querymind
DB_PASSWORD=querymind

# Derived connection string (override if using an external DB)
DATABASE_URL=postgresql://querymind:querymind@localhost:5432/querymind

# ── Database (read-only — used for query execution only) ─────────────────────
# Password must match the value in db/init/02_roles.sql
READONLY_DB_PASSWORD=querymind_ro_pass
READONLY_DATABASE_URL=postgresql://querymind_ro:querymind_ro_pass@localhost:5432/querymind

# ── Safety limits (Phase 4) ──────────────────────────────────────────────────
QUERY_ROW_LIMIT=500
QUERY_TIMEOUT_MS=5000

# ── Backend server ────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=info
